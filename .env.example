# =============================================================================
# Konfiguration für docker compose. Datei nach .env kopieren und anpassen.
# =============================================================================

# -- Common -------------------------------------------------------------------
STACK_NAME=pocketbase-collab
TIME_ZONE=Etc/UTC

# -- PocketBase ---------------------------------------------------------------
PB_VERSION=0.39.4

# App-Login (Collection "users") – wird nur beim allerersten Start gesetzt.
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=demo1234

# Superuser fürs Admin-Dashboard (/_/) – ebenfalls nur beim ersten Start.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=demoadmin1234

# -- Ports (development / coolify / standalone) -------------------------------
# Einheitliches Routing: Nginx (Frontend) ist der einzige Eingang und proxied
# /api + /_/ intern an PocketBase. APP_PORT ist der öffentliche Port.
APP_PORT=8080
# Nur im development-Compose: PocketBase zusätzlich direkt (für `vite dev`).
PB_PORT=8090

# -- Production hinter EXTERNEM Traefik (docker-compose.traefik.yml) -----------
# Name des EXTERNEN Traefik-Docker-Netzwerks (muss bereits existieren).
PROXY_NETWORK=EDGEPROXY
# Name des ACME/Let's-Encrypt certresolvers in eurer Traefik-Instanz.
TLS_CERTRESOLVER=letsencrypt
# EIN Hostname – DNS muss auf den Server zeigen. Nginx serviert App + /api + /_/.
SERVICE_HOSTNAME=collab.example.com

# -- Optional: Registry-Image-Namen / -Version überschreiben ------------------
# IMAGE_PB=ghcr.io/bauer-group/pocketbase-collab/pocketbase
# IMAGE_WEB=ghcr.io/bauer-group/pocketbase-collab/frontend
# APP_VERSION=latest
